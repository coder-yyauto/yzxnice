# yzxnice 环境变量模板
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 警告：.env 已在 .gitignore 中，永远不要把含真实密钥的 .env 提交进 git。
# 任何"默认值"都是公开的——生产部署必须用 secrets manager 或手工覆写。

# JWT / session 签名密钥（必填，**生产环境必须随机生成**，例如 `python -c "import secrets; print(secrets.token_urlsafe(48))"`）
SECRET_KEY=change-me-to-a-random-string-min-32-chars

# 数据库连接字符串
DATABASE_URL=duckdb:///data/yzxnice.duckdb

# 学生与教师账号的默认初始密码（仅在 init_data.py 初次种子时使用）
# 生产环境必须用一次性邀请链接/邮件发送，不要让所有账号共享同一密码
DEFAULT_PASSWORD=CHANGE_ME_BEFORE_INIT

# 浏览器标签页标题
APP_TITLE=教学模拟平台

# 上传目录（相对项目根）
UPLOAD_DIR=static/uploads

# 测试模式（true=简化校验便于跑测试）
TEST_MODE=false

# 初始管理员密码（留空则不创建 admin 账号）
INIT_ADMIN_PASSWORD=
